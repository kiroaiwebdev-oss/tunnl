<?xml version="1.0" encoding="utf-8"?>
<!-- Brand-colour circle that fills the adaptive-icon canvas. Drawing the
     background as a circle (instead of a full square colour) keeps the launcher
     icon circular even on launchers that apply a square / squircle mask. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#0D2233"
        android:pathData="M54,54 m-54,0 a54,54 0 1,0 108,0 a54,54 0 1,0 -108,0" />
</vector>
