# Allow public read of profile images, but never let PHP execute here.
# Apache 2.4 (shared hosting standard)
<FilesMatch "\.(php|php5|phtml|pl|py|jsp|asp|sh|cgi)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

Options -Indexes -ExecCGI
AddType image/jpeg  .jpg .jpeg
AddType image/png   .png
AddType image/webp  .webp
